# Provider selection: openai | anthropic | ollama
# Default for local dev in this project:
LLM_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# If you use OpenAI or Anthropic, switch LLM_PROVIDER above and fill the matching key.

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11400
OLLAMA_MODEL=qwen2.5:3b

# Existing Go backend base URL
API_BASE_URL=http://localhost:8080
